{
  "name": "@shuji-bonji/pdf-writer-mcp",
  "version": "0.1.0",
  "description": "MCP server that generates PDFs from text, Markdown, or tabular data using pdf-lib, with Japanese font embedding (fontkit subset).",
  "type": "module",
  "bin": {
    "pdf-writer-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pdf",
    "pdf-lib",
    "markdown-to-pdf"
  ],
  "author": "shuji-bonji",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shuji-bonji/pdf-writer-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "marked": "^18.0.6",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
